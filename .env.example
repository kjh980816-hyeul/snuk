# ===== 치직온(CHZIKON) 운영 환경변수 예시 =====
# 실제 값은 서버 env(또는 systemd EnvironmentFile)로 주입. git 커밋 금지.

# --- 프로파일 ---
SPRING_PROFILES_ACTIVE=prod

# --- DB (MySQL 8, utf8mb4) ---
DB_URL=jdbc:mysql://localhost:3306/chzikon?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=chzikon
DB_PASSWORD=__change_me__

# --- JWT (랜덤: openssl rand -base64 64) ---
JWT_SECRET=__openssl_rand_base64_64__

# --- 게임 키 암호화 키 (AES-256, base64 32바이트: openssl rand -base64 32) ---
KEY_ENCRYPTION_SECRET=__openssl_rand_base64_32__

# --- 치지직 OAuth (developers.chzzk.naver.com 에서 발급, 앱이름에 chzzk/치지직/naver 불가 → CHZIKON) ---
CHZZK_CLIENT_ID=__chzzk_client_id__
CHZZK_CLIENT_SECRET=__chzzk_client_secret__
CHZZK_REDIRECT_URI=https://your-domain.com/login/oauth2/code/chzzk

# --- 대표(ADMIN) 고정: 대표 치지직 채널ID ---
CHZZK_ADMIN_CHANNEL_ID=__chzzk_channel_id_of_owner__

# --- CORS / 프론트 ---
CORS_ALLOWED_ORIGINS=https://your-domain.com
FRONTEND_REDIRECT_BASE=https://your-domain.com

# --- PortOne(V2) 결제 (admin.portone.io 에서 발급) ---
# store-id / channel-key 는 공개값(프론트 결제창 호출), api-secret 은 비밀값(서버 결제 검증)
PORTONE_STORE_ID=store-________________________________
PORTONE_CHANNEL_KEY=channel-________________________________
PORTONE_API_SECRET=__portone_api_secret__
# 웹훅 등록 주소(PortOne 콘솔): https://your-domain.com/api/payments/webhook
